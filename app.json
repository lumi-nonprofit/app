{
  "expo": {
    "name": "Lumi",
    "slug": "lumi",
    "version": "0.1.0",
    "scheme": "lumi",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FBF7EF"
        }
      ],
      "expo-router",
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF7EF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Lumi",
      "shortName": "Lumi",
      "lang": "cs",
      "themeColor": "#FBF7EF",
      "backgroundColor": "#FBF7EF",
      "description": "Lumi — aplikace pro podporu duševní pohody. Check-in emocí, klidová cvičení a pomoc v krizi. Česky a zdarma."
    }
  }
}
